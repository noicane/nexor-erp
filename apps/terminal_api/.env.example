# NEXOR Terminal API - Environment Variables
# .env dosyasi yapip burayi referans alin (gercek deploy oncesi degistirin)

# JWT - 32+ karakter rastgele string
TERMINAL_JWT_SECRET=change-me-in-production-min-32-bytes

# Token gecerlilik suresi
TERMINAL_JWT_EXPIRES_HOURS=8

# Sunucu
TERMINAL_API_HOST=0.0.0.0
TERMINAL_API_PORT=8002

TERMINAL_LOG_LEVEL=INFO
