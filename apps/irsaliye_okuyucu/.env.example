# Anthropic API Key - https://console.anthropic.com/ uzerinden al
# sk-ant-api03-... ile baslar
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Model (varsayilan: claude-haiku-4-5 - ucuz ve hizli)
# Daha yuksek dogruluk icin: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Sunucu portu
PORT=8000

# NEXOR DB - .env'de ayni UDL bilgileri (default: Nexor.UDL'den otomatik okunur)
# Bos birakirsan proje kokundeki Nexor.UDL dosyasindan okur
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
