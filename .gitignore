# =========================
# NEXOR ERP - .gitignore
# =========================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/

# Virtual environments
venv/
ENV/
.venv/

# PyInstaller / Build
build/
dist/
*.spec
*.exe
*.msi

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/
*.log.*

# Config (hassas veriler - örnek dosya kullan)
config.json
*.local.json
*.local.py
settings.json

# Ortam dosyalari (API key'ler, sifreler)
.env
.env.*
!.env.example
apps/*/.env
apps/*/uploads/
apps/*/.venv/

# Database
*.db
*.sqlite
*.sqlite3
*.mdb

# Backup files
*.bak
*.backup
*_backup/
config_backups/

# Temp files
*.tmp
*.temp
.cache/

# Gecici gelistirme scriptleri (push'lanmamali)
scripts/_temp_*.py
scripts/_test_*.py

# MCP / Claude Code yerel ayarlari
.mcp.json
.claude/

# Musteri logolari (kisisel veri)
logos/
config/logos/

# Flutter project icinde generated/local
apps/nexor_terminal/.dart_tool/
apps/nexor_terminal/build/
apps/nexor_terminal/.flutter-plugins
apps/nexor_terminal/.flutter-plugins-dependencies
apps/nexor_terminal/android/local.properties
apps/nexor_terminal/android/key.properties
apps/nexor_terminal/android/**/keystore.jks

# Test
.pytest_cache/
.coverage
htmlcov/
.tox/

# Reports / Outputs
reports/
exports/
*.pdf
*.xlsx
!docs/**/*.pdf

# User data
.redline_nexor/

# Empty directories (git doesn't track them anyway)
pybuild/
nul
Nexor.UDL
core/Nexor.UDL
PyWhatKit_DB.txt
