# =========================
# NEXOR ERP - .gitignore
# =========================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/

# Virtual environments
venv/
ENV/
.venv/

# PyInstaller / Build
build/
dist/
*.spec
*.exe
*.msi

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/
*.log.*

# Config (hassas veriler - örnek dosya kullan)
config.json
*.local.json
*.local.py
settings.json

# Database
*.db
*.sqlite
*.sqlite3
*.mdb

# Backup files
*.bak
*.backup
*_backup/
config_backups/

# Temp files
*.tmp
*.temp
.cache/

# Test
.pytest_cache/
.coverage
htmlcov/
.tox/

# Reports / Outputs
reports/
exports/
*.pdf
*.xlsx
!docs/**/*.pdf

# User data
.redline_nexor/

# Empty directories (git doesn't track them anyway)
pybuild/
nul
Nexor.UDL
core/Nexor.UDL
PyWhatKit_DB.txt
